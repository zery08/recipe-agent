SUPERVISOR_MODEL=z-ai/glm-4.7
SUPERVISOR_BASE_URL=https://openrouter.ai/api/v1
SUPERVISOR_API_KEY=

# Optional. TOOL_* falls back to SUPERVISOR_* when not set.
# TOOL_MODEL=
# TOOL_BASE_URL=
# TOOL_API_KEY=

# Optional Phoenix/OpenInference observability.
# PHOENIX_ENDPOINT should point at the OTLP traces endpoint, e.g. http://localhost:6006/v1/traces.
# PHOENIX_ENDPOINT=
# PHOENIX_PROJECT_NAME=recipe-agent
