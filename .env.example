SUPERVISOR_MODEL=z-ai/glm-4.7
SUPERVISOR_BASE_URL=https://openrouter.ai/api/v1
SUPERVISOR_API_KEY=

# Optional. TOOL_* falls back to SUPERVISOR_* when not set.
# TOOL_MODEL=
# TOOL_BASE_URL=
# TOOL_API_KEY=

# Phoenix/OpenTelemetry tracing.
# gRPC collector endpoint. Local Phoenix usually listens on 4317.
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://localhost:4317
PHOENIX_PROJECT_NAME=recipe-agent

# SQLAlchemy URI for LangChain SQLDatabaseToolkit.
# Local test SQLite DB:
CLICKHOUSE_URI=sqlite:///data/recipe_agent_test.db
# ClickHouse example: clickhousedb://default:password@localhost:8123/default
